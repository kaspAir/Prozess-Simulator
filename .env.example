# Anpassen und als .env speichern

# Standard: SQLite (kein DB-Server noetig). Die Datei wird im Arbeitsverzeichnis
# bzw. im gemounteten Daten-Volume angelegt.
DATABASE_URL=sqlite:///prozess_simulator.db

# Alternative PostgreSQL (psycopg2-binary muss installiert sein):
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/prozess_simulator

# In Produktion zwingend durch einen langen, zufaelligen Wert ersetzen!
FLASK_SECRET_KEY=dev-secret
